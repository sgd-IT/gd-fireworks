<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.monkey.general.modules.bz.mapper.ArticleMapper">

    <select id="queryPageViewModel" resultType="com.monkey.general.modules.bz.dto.ArticleViewModel">
        SELECT ac.category_name,a.* FROM bz_article a
            LEFT JOIN bz_article_category ac on a.category_id=ac.id
        ${ew.customSqlSegment}
    </select>

</mapper>