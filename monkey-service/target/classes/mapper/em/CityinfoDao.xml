<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.monkey.general.modules.em.dao.CityinfoDao">
    <resultMap id="NodeTreeResult" type="com.monkey.general.modules.em.dto.CityViewModel">
        <result column="id" property="id"/>
        <result column="num" property="num"/>
        <result column="name" property="name"/>
        <result column="parent_id" property="parentId"/>
        <result column="flag" property="flag"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="data_status" property="dataStatus"/>
        <collection property="childNode"  ofType="com.monkey.general.modules.em.dto.CityViewModel" column="num" select="nextgetListInfos" javaType="java.util.ArrayList">

        </collection>
    </resultMap>



    <select id="getListInfo" resultMap="NodeTreeResult">
        select
            id,num,name, parent_id
        from em_cityinfo
        where parent_id='0'
    </select>

    <select id="nextgetListInfos" resultMap="NodeTreeResult">
        select
            id,num,name, parent_id
        from em_cityinfo
        where parent_id=#{num}
    </select>

</mapper>