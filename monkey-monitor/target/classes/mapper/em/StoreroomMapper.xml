<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.monkey.general.modules.em.mapper.StoreroomMapper">

    <select id="selectListPages" resultType="com.monkey.general.modules.em.entity.Storeroom">
        select sr.*,wh.store_name from em_storeroom sr
        LEFT JOIN em_warehouse wh on sr.store_num = wh.store_num
            ${ew.customSqlSegment}
    </select>

</mapper>
